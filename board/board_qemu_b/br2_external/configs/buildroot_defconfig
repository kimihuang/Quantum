# Buildroot defconfig for board_qemu_b
# Target: QEMU virt platform (ARM64) with different configuration

BR2_aarch64=y
BR2_ARCH=y
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TARGET_GENERIC_GETTY_PORT="ttyAMA0"
BR2_TARGET_ROOTFS_EXT2=y
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_USE_ARCH_DEFAULT_CONFIG=y
BR2_INIT_SYSTEMD=y
